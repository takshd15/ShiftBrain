# Copy this file to .env and fill in local values.
# Never commit .env.

# Supabase project API settings
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only key. Keep this out of browser code.
SUPABASE_SERVICE_KEY=

# Optional direct Postgres connection string for migrations/admin scripts.
# Prefer Supabase SQL Editor unless a script explicitly needs DATABASE_URL.
DATABASE_URL=

# Model provider used by server.js
GEMINI_API_KEY=

# Optional OpenAI-compatible vision/model endpoint
VLLM_URL=
VLLM_KEY=
VLLM_MODEL=

# Express server port
PORT=3001
